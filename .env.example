# Toggle cloud sync in browser/client code
NEXT_PUBLIC_ENABLE_CLOUD_SYNC=1

# Supabase project URL (Dashboard -> Settings -> API)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Server-only secret key (Dashboard -> Settings -> API)
# Put this in Netlify environment variables. Do not expose in client code.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
